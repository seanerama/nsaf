# ============================================
# NSAF — Nightshift AutoFoundry Configuration
# ============================================
# Copy this file to .env and fill in all values.

# --- AI API Keys (Idea Generation) ---
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=
NSAF_OWNER_EMAIL=

# --- Webex Bot ---
WEBEX_BOT_TOKEN=
WEBEX_WEBHOOK_SECRET=
WEBEX_OWNER_PERSON_ID=

# --- ngrok (required for Webex webhook) ---
NGROK_AUTHTOKEN=

# --- Coolify (Self-Hosted PaaS for Promotion) ---
COOLIFY_API_URL=https://coolify.yourdomain.com
COOLIFY_API_TOKEN=
COOLIFY_PROJECT_UUID=
COOLIFY_SERVER_UUID=
COOLIFY_ENVIRONMENT=production
NSAF_DOMAIN=yourdomain.com

# --- PostgreSQL (App Databases) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=

# --- Orchestrator Settings ---
NSAF_PROJECTS_DIR=./projects
NSAF_PORT_RANGE_START=5020
NSAF_PORT_RANGE_END=5999
NSAF_CONCURRENCY=2
NSAF_STALL_TIMEOUT_MINUTES=30
NSAF_POLL_INTERVAL_SECONDS=30
NSAF_QUEUE_POLL_INTERVAL_SECONDS=10

# --- Flask App ---
NSAF_FLASK_PORT=5000
NSAF_FLASK_HOST=0.0.0.0

# --- Claude Code ---
NSAF_CLAUDE_COMMAND=claude -p "{prompt}" --dangerously-skip-permissions

# --- Database Path ---
NSAF_DB_PATH=./nsaf.db
